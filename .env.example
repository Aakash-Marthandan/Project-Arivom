# Copy to .env.local for local development. Never commit real values.

# Postgres connection (local dev: your local PostGIS-enabled database;
# production: the Supabase pooler URL).
DATABASE_URL=postgresql://localhost/arivom

# Free API key from https://data.gov.in (pipelines fall back to the public
# rate-limited sample key when unset).
# DATA_GOV_IN_API_KEY=

# Anthropic API key (console.anthropic.com) for the news clustering pipeline
# (offline LLM use only, never at page-request time; see DECISIONS.md D-022).
# Also set as a GitHub Actions secret for the hourly cluster-news cron.
# ANTHROPIC_API_KEY=
