{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/ta",
        "http://localhost:3000/ta/news"
      ],
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready",
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.8,
            "aggregationMethod": "median-run"
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95,
            "aggregationMethod": "median-run"
          }
        ]
      }
    }
  }
}